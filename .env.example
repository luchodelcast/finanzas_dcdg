# ─────────────────────────────────────────────────────────────
# DCDG Finanzas — variables de entorno
# Copia este archivo a .env y complétalo. NUNCA commitees .env.
# ─────────────────────────────────────────────────────────────

# --- Anthropic (clasificación de gastos) ---
ANTHROPIC_API_KEY=sk-ant-...
# Modelo por defecto para clasificación (reemplaza al deprecado claude-sonnet-4-20250514)
ANTHROPIC_MODEL=claude-sonnet-4-6
# Modelo económico para tareas de bajo costo (visión rápida, parseos)
ANTHROPIC_MODEL_FAST=claude-haiku-4-5-20251001

# --- Google Sheets (libro maestro DCDG) ---
GOOGLE_SPREADSHEET_ID=1c5i7gOqsRU0CCcg-B6rDDP0MlQWuQmFuT2X90Q5N4NQ
SHEET_GASTOS=Registro Gastos
SHEET_EMPRESAS=EMPRESAS
SHEET_CUENTAS=⚙️ CUENTAS

# --- Auth Google: Service Account (backend / bot) ---
# Email de la cuenta de servicio con acceso de edición al Sheet DCDG.
GOOGLE_SA_EMAIL=dcdg-finanzas@tu-proyecto.iam.gserviceaccount.com
# Clave privada de la cuenta de servicio (PEM). En Netlify pégala con los \n literales
# o en una sola línea con saltos escapados; el código normaliza ambos formatos.
GOOGLE_SA_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# --- Auth Google: OAuth de usuario (solo PWA en el navegador) ---
GOOGLE_CLIENT_ID=473061009211-972b11u9s6gpqln7n0e6tdn51vjmnv5p.apps.googleusercontent.com

# --- Integración SilvIA (Opción B: SilvIA -> API de este repo) ---
# Token de servicio compartido: SilvIA lo envía en el header Authorization: Bearer <token>.
DCDG_API_TOKEN=genera-un-token-largo-y-aleatorio
# Usuarios autorizados a usar el carril de finanzas (debe coincidir con FINANZAS_USERS en SilvIA).
FINANZAS_USERS=luis@iwin.im,carodz2@gmail.com
# Dueños (Luis/Carolina): únicos con permiso de escritura sobre asientos manuales
# del libro diario, hasta que exista un sistema de roles (T8, docs/plan-partida-doble-jul2026.md).
FINANZAS_OWNERS=luis@iwin.im,carodz2@gmail.com
